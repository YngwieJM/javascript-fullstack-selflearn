{
  "openapi": "3.0.3",
  "info": {
    "title": "Restaurant API - Reports",
    "version": "1.0.0",
    "description": "Reports endpoints for sales analytics. All endpoints require MANAGER role."
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "tags": [
    {
      "name": "Reports"
    }
  ],
  "paths": {
    "/reports/daily-sales": {
      "get": {
        "tags": [
          "Reports"
        ],
        "summary": "Daily sales summary",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Daily sales rows",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DailySalesRow"
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/reports/top-menu": {
      "get": {
        "tags": [
          "Reports"
        ],
        "summary": "Top selling menu items",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Top menu rows",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TopMenuRow"
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/reports/revenue": {
      "get": {
        "tags": [
          "Reports"
        ],
        "summary": "Total revenue",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Revenue aggregate",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RevenueRow"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/reports/sales-by-staff": {
      "get": {
        "tags": [
          "Reports"
        ],
        "summary": "Sales grouped by staff",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Sales by staff rows",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SalesByStaffRow"
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/reports/sales-by-category": {
      "get": {
        "tags": [
          "Reports"
        ],
        "summary": "Sales grouped by menu category",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Sales by category rows",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SalesByCategoryRow"
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/reports/hourly-sales": {
      "get": {
        "tags": [
          "Reports"
        ],
        "summary": "Hourly sales summary",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Hourly sales rows",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/HourlySalesRow"
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "responses": {
      "UnauthorizedError": {
        "description": "Unauthorized request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "ForbiddenError": {
        "description": "Forbidden request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "InternalServerError": {
        "description": "Internal server error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "required": [
          "message"
        ],
        "properties": {
          "message": {
            "type": "string"
          }
        }
      },
      "DailySalesRow": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string"
          },
          "total_orders": {
            "type": "string"
          },
          "total_revenue": {
            "type": "string"
          }
        }
      },
      "TopMenuRow": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "total_sold": {
            "type": "string"
          }
        }
      },
      "RevenueRow": {
        "type": "object",
        "properties": {
          "total_revenue": {
            "type": "string"
          }
        }
      },
      "SalesByStaffRow": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "total_orders": {
            "type": "string"
          },
          "total_revenue": {
            "type": "string"
          }
        }
      },
      "SalesByCategoryRow": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string"
          },
          "total_items_sold": {
            "type": "string"
          },
          "total_revenue": {
            "type": "string"
          }
        }
      },
      "HourlySalesRow": {
        "type": "object",
        "properties": {
          "hour": {
            "type": "string"
          },
          "total_orders": {
            "type": "string"
          },
          "total_revenue": {
            "type": "string"
          }
        }
      }
    }
  }
}
