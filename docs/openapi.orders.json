{
  "openapi": "3.0.3",
  "info": {
    "title": "Restaurant API - Orders",
    "version": "1.0.0",
    "description": "Minimal OpenAPI contract for orders endpoints only."
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "paths": {
    "/orders": {
      "post": {
        "summary": "Create order (WAITER or MANAGER)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrderRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Order created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateOrderResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          }
        },
        "tags": [
          "Orders"
        ]
      },
      "get": {
        "summary": "Get all orders (MANAGER only)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Orders list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetAllOrdersResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          }
        },
        "tags": [
          "Orders"
        ]
      }
    },
    "/orders/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "pattern": "^\\d+$"
          }
        }
      ],
      "get": {
        "summary": "Get order by id (WAITER or MANAGER)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Order detail",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetOrderByIdResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          }
        },
        "tags": [
          "Orders"
        ]
      },
      "delete": {
        "summary": "Delete order (MANAGER only)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Order deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteOrderResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          }
        },
        "tags": [
          "Orders"
        ]
      }
    },
    "/orders/{id}/items": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "pattern": "^\\d+$"
          }
        }
      ],
      "post": {
        "summary": "Add menu item to order (WAITER or MANAGER)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddOrderItemRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Order item added",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AddOrderItemResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          }
        },
        "tags": [
          "Orders"
        ]
      }
    },
    "/orders/{id}/close": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "pattern": "^\\d+$"
          }
        }
      ],
      "patch": {
        "summary": "Close order (WAITER or MANAGER)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Order closed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CloseOrderResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          }
        },
        "tags": [
          "Orders"
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "responses": {
      "ValidationError": {
        "description": "Validation error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ValidationErrorResponse"
            }
          }
        }
      },
      "BadRequest": {
        "description": "Validation or business-rule error",
        "content": {
          "application/json": {
            "schema": {
              "oneOf": [
                {
                  "$ref": "#/components/schemas/ValidationErrorResponse"
                },
                {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              ]
            }
          }
        }
      },
      "UnauthorizedError": {
        "description": "Unauthorized",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "ForbiddenError": {
        "description": "Forbidden",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFoundError": {
        "description": "Not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "OrderCore": {
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "table_id": {
            "type": "integer"
          },
          "staff_id": {
            "type": "integer"
          },
          "status": {
            "type": "string"
          },
          "created_at": {
            "type": "string"
          }
        }
      },
      "OrderListItem": {
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "status": {
            "type": "string"
          },
          "created_at": {
            "type": "string"
          },
          "table_number": {
            "type": "string"
          },
          "staff_name": {
            "type": "string"
          }
        }
      },
      "OrderItem": {
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "order_id": {
            "type": "integer"
          },
          "menu_item_id": {
            "type": "integer"
          },
          "quantity": {
            "type": "integer",
            "minimum": 1
          },
          "price_at_time": {
            "type": "number"
          }
        }
      },
      "OrderDetailItem": {
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "quantity": {
            "type": "integer",
            "minimum": 1
          },
          "price_at_time": {
            "type": "number"
          },
          "subtotal": {
            "type": "number"
          }
        }
      },
      "OrderDetail": {
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "status": {
            "type": "string"
          },
          "created_at": {
            "type": "string"
          },
          "staff_id": {
            "type": "integer"
          },
          "table_number": {
            "type": "string"
          },
          "staff_name": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderDetailItem"
            }
          },
          "total": {
            "type": "number"
          }
        }
      },
      "CreateOrderRequest": {
        "type": "object",
        "required": [
          "table_id"
        ],
        "properties": {
          "table_id": {
            "type": "integer",
            "minimum": 1
          },
          "staff_id": {
            "type": "integer",
            "minimum": 1
          }
        }
      },
      "AddOrderItemRequest": {
        "type": "object",
        "required": [
          "menu_item_id",
          "quantity"
        ],
        "properties": {
          "menu_item_id": {
            "type": "integer",
            "minimum": 1
          },
          "quantity": {
            "type": "integer",
            "minimum": 1
          }
        }
      },
      "CreateOrderResponse": {
        "type": "object",
        "required": [
          "message",
          "order"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "order": {
            "$ref": "#/components/schemas/OrderCore"
          }
        }
      },
      "AddOrderItemResponse": {
        "type": "object",
        "required": [
          "message",
          "orderItem"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "orderItem": {
            "$ref": "#/components/schemas/OrderItem"
          }
        }
      },
      "GetAllOrdersResponse": {
        "type": "object",
        "required": [
          "message",
          "orders"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "orders": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderListItem"
            }
          }
        }
      },
      "GetOrderByIdResponse": {
        "type": "object",
        "required": [
          "message",
          "order"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "order": {
            "$ref": "#/components/schemas/OrderDetail"
          }
        }
      },
      "CloseOrderResponse": {
        "type": "object",
        "required": [
          "message",
          "order"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "order": {
            "$ref": "#/components/schemas/OrderCore"
          }
        }
      },
      "DeleteOrderResponse": {
        "type": "object",
        "required": [
          "message",
          "order"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "order": {
            "$ref": "#/components/schemas/OrderCore"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "message"
        ],
        "properties": {
          "message": {
            "type": "string"
          }
        }
      },
      "ValidationErrorResponse": {
        "type": "object",
        "required": [
          "message",
          "errors"
        ],
        "properties": {
          "message": {
            "type": "string",
            "enum": [
              "Validation error"
            ]
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Auth"
    },
    {
      "name": "Staff"
    },
    {
      "name": "Menu"
    },
    {
      "name": "Orders"
    },
    {
      "name": "Tables"
    },
    {
      "name": "Reports"
    }
  ]
}
