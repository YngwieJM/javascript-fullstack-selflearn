{
  "info": {
    "name": "Restaurant API - Models",
    "description": "Collection grouped by model for Auth, Menu, Orders, Staff, Tables, and Reports APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000" },
    { "key": "access_token", "value": "" },
    { "key": "reset_token", "value": "" },
    { "key": "menu_id", "value": "1" },
    { "key": "order_id", "value": "1" },
    { "key": "table_id", "value": "1" },
    { "key": "staff_id", "value": "1" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John\",\n  \"email\": \"john@example.com\",\n  \"password\": \"123456\",\n  \"role\": \"WAITER\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/register" }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('access_token', json.token);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"manager@example.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login" }
          }
        },
        {
          "name": "Forgot Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.resetToken) pm.collectionVariables.set('reset_token', json.resetToken);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"manager@example.com\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/forgot-password" }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{reset_token}}\",\n  \"newPassword\": \"123456\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/reset-password" }
          }
        }
      ]
    },
    {
      "name": "Menu",
      "item": [
        {
          "name": "Get All Menu (Paginated)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/menu?page=1&limit=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Menu By Id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/menu/{{menu_id}}" }
          }
        },
        {
          "name": "Create Menu",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Burger\",\n  \"category\": \"FOOD\",\n  \"price\": 50000\n}"
            },
            "url": { "raw": "{{base_url}}/menu" }
          }
        },
        {
          "name": "Update Menu",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Cheese Burger\",\n  \"price\": 55000\n}"
            },
            "url": { "raw": "{{base_url}}/menu/{{menu_id}}" }
          }
        },
        {
          "name": "Toggle Availability",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_available\": false\n}"
            },
            "url": { "raw": "{{base_url}}/menu/{{menu_id}}/availability" }
          }
        },
        {
          "name": "Delete Menu",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/menu/{{menu_id}}" }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Get All Orders (Paginated)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/orders?page=1&limit=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Order By Id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/orders/{{order_id}}" }
          }
        },
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"table_id\": 1,\n  \"staff_id\": 1\n}"
            },
            "url": { "raw": "{{base_url}}/orders" }
          }
        },
        {
          "name": "Add Item To Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"menu_item_id\": 1,\n  \"quantity\": 2\n}"
            },
            "url": { "raw": "{{base_url}}/orders/{{order_id}}/items" }
          }
        },
        {
          "name": "Close Order",
          "request": {
            "method": "PATCH",
            "url": { "raw": "{{base_url}}/orders/{{order_id}}/close" }
          }
        },
        {
          "name": "Delete Order",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/orders/{{order_id}}" }
          }
        }
      ]
    },
    {
      "name": "Staff",
      "item": [
        {
          "name": "Get All Staff (Paginated)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/staff?page=1&limit=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Staff By Id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/staff/{{staff_id}}" }
          }
        },
        {
          "name": "Create Staff",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Anna\",\n  \"email\": \"anna@example.com\",\n  \"password\": \"123456\",\n  \"role\": \"WAITER\"\n}"
            },
            "url": { "raw": "{{base_url}}/staff" }
          }
        },
        {
          "name": "Update Staff",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Anna Updated\",\n  \"email\": \"anna.updated@example.com\",\n  \"role\": \"BARTENDER\"\n}"
            },
            "url": { "raw": "{{base_url}}/staff/{{staff_id}}" }
          }
        },
        {
          "name": "Update Password",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"123456\",\n  \"newPassword\": \"1234567\"\n}"
            },
            "url": { "raw": "{{base_url}}/staff/{{staff_id}}" }
          }
        },
        {
          "name": "Delete Staff",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/staff/{{staff_id}}" }
          }
        }
      ]
    },
    {
      "name": "Tables",
      "item": [
        {
          "name": "Get All Tables (Paginated)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/tables?page=1&limit=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Table By Id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/tables/{{table_id}}" }
          }
        },
        {
          "name": "Create Table",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"table_number\": \"T5\",\n  \"capacity\": 4\n}"
            },
            "url": { "raw": "{{base_url}}/tables" }
          }
        },
        {
          "name": "Update Table",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"table_number\": \"T5\",\n  \"capacity\": 6\n}"
            },
            "url": { "raw": "{{base_url}}/tables/{{table_id}}" }
          }
        },
        {
          "name": "Delete Table",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/tables/{{table_id}}" }
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Daily Sales",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/reports/daily-sales" }
          }
        },
        {
          "name": "Top Menu",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/reports/top-menu" }
          }
        },
        {
          "name": "Revenue",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/reports/revenue" }
          }
        },
        {
          "name": "Sales By Staff",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/reports/sales-by-staff" }
          }
        },
        {
          "name": "Sales By Category",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/reports/sales-by-category" }
          }
        },
        {
          "name": "Hourly Sales",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/reports/hourly-sales" }
          }
        }
      ]
    }
  ]
}
