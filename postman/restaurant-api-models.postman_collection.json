{
  "info": {
    "name": "Restaurant API - Models",
    "description": "Collection grouped by model for Auth, Menu, Orders, Staff, Tables, and Reports APIs. Uses stateful session cookie auth (login first).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "noauth"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    },
    {
      "key": "manager_email",
      "value": "admin@test.com"
    },
    {
      "key": "manager_password",
      "value": "123456"
    },
    {
      "key": "report_date",
      "value": "2026-03-14"
    },
    {
      "key": "menu_id",
      "value": "1"
    },
    {
      "key": "order_id",
      "value": "1"
    },
    {
      "key": "table_id",
      "value": "1"
    },
    {
      "key": "staff_id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John\",\n  \"email\": \"john@example.com\",\n  \"password\": \"123456\",\n  \"role\": \"WAITER\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Login success\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.user && json.user.id) pm.collectionVariables.set(\"staff_id\", String(json.user.id));"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{manager_email}}\",\n  \"password\": \"{{manager_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login"
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/me"
            },
            "auth": {
              "type": "noauth"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/logout"
            },
            "auth": {
              "type": "noauth"
            }
          }
        }
      ]
    },
    {
      "name": "Menu",
      "item": [
        {
          "name": "Get All Menu (Paginated)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/menu?page=1&limit=10",
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "auth": {
              "type": "noauth"
            }
          }
        },
        {
          "name": "Get Menu By Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/menu/{{menu_id}}"
            },
            "auth": {
              "type": "noauth"
            }
          }
        },
        {
          "name": "Create Menu",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Burger\",\n  \"category\": \"FOOD\",\n  \"price\": 50000\n}"
            },
            "url": {
              "raw": "{{base_url}}/menu"
            },
            "auth": {
              "type": "noauth"
            }
          }
        },
        {
          "name": "Update Menu",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Cheese Burger\",\n  \"price\": 55000\n}"
            },
            "url": {
              "raw": "{{base_url}}/menu/{{menu_id}}"
            },
            "auth": {
              "type": "noauth"
            }
          }
        },
        {
          "name": "Toggle Availability",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_available\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/menu/{{menu_id}}/availability"
            },
            "auth": {
              "type": "noauth"
            }
          }
        },
        {
          "name": "Delete Menu",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/menu/{{menu_id}}"
            },
            "auth": {
              "type": "noauth"
            }
          }
        }
      ]
    },
